# PipeWipe Professional Backend - Environment Variables
# Copy this file to .env and adjust the values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port
PORT=3001

# Node environment (development | production | test)
NODE_ENV=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# FILE PROCESSING
# =============================================================================

# Maximum file size in MB
MAX_FILE_SIZE=100

# Maximum number of files in batch
MAX_BATCH_FILES=50

# Upload directory (relative to project root)
UPLOAD_DIR=uploads

# Cleaned files directory (relative to project root)
CLEANED_DIR=cleaned

# Temporary files directory
TEMP_DIR=temp

# Auto-delete uploaded files after processing (true | false)
AUTO_DELETE_UPLOADS=true

# Auto-delete cleaned files after download (hours)
AUTO_DELETE_CLEANED_HOURS=24

# =============================================================================
# METADATA EXTRACTION
# =============================================================================

# ExifTool configuration
EXIFTOOL_TIMEOUT=30000
EXIFTOOL_MAX_PROC=4

# FFmpeg configuration
FFMPEG_TIMEOUT=60000

# Enable/disable specific engines
ENABLE_EXIFTOOL=true
ENABLE_FFMPEG=true
ENABLE_POPPLER=true

# =============================================================================
# LOGGING
# =============================================================================

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# Log directory
LOG_DIR=logs

# Log file rotation (days)
LOG_ROTATION_DAYS=7

# =============================================================================
# RATE LIMITING
# =============================================================================

# Enable rate limiting
ENABLE_RATE_LIMIT=true

# Rate limit window (minutes)
RATE_LIMIT_WINDOW=15

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# SECURITY
# =============================================================================

# Enable helmet security headers
ENABLE_HELMET=true

# Enable compression
ENABLE_COMPRESSION=true

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.bmp,.tiff,.svg,.heic,.heif,.mp4,.mov,.avi,.mkv,.webm,.flv,.wmv,.mp3,.wav,.flac,.aac,.ogg,.m4a,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip,.rar

# =============================================================================
# API CONFIGURATION
# =============================================================================

# API version
API_VERSION=v1

# API base path
API_BASE_PATH=/api

# Enable API documentation
ENABLE_API_DOCS=true
