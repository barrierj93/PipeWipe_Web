# PipeWipe Professional - Environment Variables
# Copia este archivo a .env.local y ajusta los valores según tu configuración

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================

# URL del backend de PipeWipe (Node.js + Express)
# En desarrollo local, normalmente es http://localhost:3001
# En producción, usa la URL de tu backend desplegado
BACKEND_URL=http://localhost:3001

# URL pública de la API (usada por el frontend)
# Debe apuntar al proxy de Next.js que redirige al backend
# En desarrollo: http://localhost:3000/api/backend
# En producción: https://tu-dominio.com/api/backend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/backend

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Entorno de ejecución (development | production | test)
NODE_ENV=development

# Puerto del servidor Next.js (por defecto 3000)
PORT=3000

# =============================================================================
# FILE UPLOAD LIMITS
# =============================================================================

# Tamaño máximo de archivo individual (en MB)
NEXT_PUBLIC_MAX_FILE_SIZE=100

# Número máximo de archivos en batch processing
NEXT_PUBLIC_MAX_BATCH_FILES=50

# =============================================================================
# FEATURE FLAGS (Opcional)
# =============================================================================

# Habilitar modo debug con logs adicionales
NEXT_PUBLIC_DEBUG_MODE=false

# Habilitar análisis de mapa (requiere coordenadas GPS)
NEXT_PUBLIC_ENABLE_MAP_VIEW=true

# Habilitar comparador de archivos
NEXT_PUBLIC_ENABLE_FILE_COMPARISON=true

# =============================================================================
# EXTERNAL SERVICES (Opcional - para features avanzadas)
# =============================================================================

# API Key para Mapbox (si usas Mapbox en lugar de Leaflet)
# NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Sentry DSN para error tracking (opcional)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# SECURITY
# =============================================================================

# Secret para JWT (si implementas autenticación en el futuro)
# JWT_SECRET=your_secret_key_here

# Allowed origins para CORS
# ALLOWED_ORIGINS=http://localhost:3000,https://tu-dominio.com
